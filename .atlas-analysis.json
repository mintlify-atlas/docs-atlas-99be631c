  "keyFeatures": [
    "Better-Auth with multiple OAuth providers (Google, GitHub, Microsoft, Facebook)",
    "Multi-provider payment integration (Stripe, Polar, LemonSqueezy, Autumn, Dodo, Creem)",
    "Subscription management with Free, Starter, Pro, and Enterprise tiers",
    "Email service with multiple providers (Resend, Postmark, Plunk, Nodemailer)",
    "PostgreSQL database with Drizzle ORM",
    "Internationalization support (English, French, Spanish)",
    "Cloudflare R2 storage integration",
    "Modern UI with TailwindCSS 4 and BaseUI components",
    "Built with Next.js 16 App Router and Bun runtime",
    "Sentry integration for error tracking"
  ],
  "publicApiSurface": [
    "/api/auth/* - Better-Auth authentication endpoints",
    "/api/payments/* - Payment processing endpoints",
    "/api/webhooks/* - Webhook handlers for payment providers",
    "auth client and server helpers from Better-Auth",
    "Payment service adapters for Stripe, Polar, LemonSqueezy",
    "Email mailer with provider abstraction",
    "Drizzle ORM schema and database connection",
    "Storage client for Cloudflare R2"
  ]
